# LNN Hub — environment variables
# Copy this file to .env and fill in values for the target Supabase project.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon / publishable key (safe for the browser; protected by RLS)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project ref, e.g. xxxxxxxx
VITE_SUPABASE_PROJECT_ID=

# Canonical app URL for external-facing links (Slack, emails).
# Leave blank to use the current origin.
# Prod example: https://client.lnn.co   Staging example: https://staging.lnn.co
VITE_APP_BASE_URL=
